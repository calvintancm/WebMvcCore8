@if (User.Identity?.IsAuthenticated == true)
{
    <ul class="navbar-nav">
        <li class="nav-item">
            <span class="nav-link text-dark">
                Hello, <strong>@User.Identity.Name</strong>
            </span>
        </li>
        <li class="nav-item">
            <form method="post"
                  asp-controller="Account"
                  asp-action="Logout"
                  asp-route-returnUrl="@Url.Action("Login", "Account")">
                <button type="submit" class="nav-link btn btn-link text-dark">
                    Logout
                </button>
            </form>
        </li>
    </ul>
}
else
{
    <ul class="navbar-nav">
        <li class="nav-item">
            <a class="nav-link text-dark"
               asp-controller="Account"
               asp-action="Login">
                Login
            </a>
        </li>
    </ul>
}