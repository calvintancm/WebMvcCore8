@* ═══════════════════════════════════════════
   _Navigation.cshtml — Left Sidebar
   Lighter steel-blue palette, white text
═══════════════════════════════════════════ *@
<style>
    /* ── SIDEBAR ──────────────────────────────── */
    #sidebar {
        position: fixed;
        top: 0; left: 0; bottom: 0;
        width: var(--sidebar-w);
        background: var(--sb-bg);
        display: flex;
        flex-direction: column;
        z-index: 1040;
        transition: width var(--transition);
        overflow: hidden;
    }

    body.sidebar-collapsed #sidebar { width: var(--sidebar-w-collapsed); }

    /* ── Brand bar ─────────────────────────── */
    .sb-brand {
        display: flex; align-items: center; gap: 12px;
        padding: 0 17px;
        height: var(--topbar-h);
        background: var(--sb-bg-top);
        border-bottom: 1px solid var(--sb-border);
        flex-shrink: 0;
        text-decoration: none;
        overflow: hidden;
    }

    .sb-brand-icon {
        width: 36px; height: 36px;
        background: linear-gradient(135deg, #3b96e8, #7ec8f0);
        border-radius: 9px;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
        box-shadow: 0 4px 12px rgba(59,150,232,0.45);
    }

    .sb-brand-icon i { color: #fff; font-size: 17px; }

    .sb-brand-text { overflow: hidden; transition: opacity var(--transition), width var(--transition); }

    .sb-brand-name {
        font-family: 'Sora', sans-serif;
        font-size: 0.95rem; font-weight: 700;
        color: #ffffff; white-space: nowrap; line-height: 1.2;
    }

    .sb-brand-sub {
        font-size: 0.67rem;
        color: var(--sb-text);
        white-space: nowrap;
        letter-spacing: 0.04em;
    }

    body.sidebar-collapsed .sb-brand-text { opacity: 0; width: 0; }

    /* ── User profile ─────────────────────── */
    .sb-profile {
        display: flex; align-items: center; gap: 11px;
        padding: 13px 17px;
        border-bottom: 1px solid var(--sb-border);
        flex-shrink: 0; overflow: hidden;
        background: rgba(0,0,0,0.08);
    }

    .sb-avatar {
        width: 36px; height: 36px; border-radius: 50%;
        background: linear-gradient(135deg, var(--gold), var(--gold-lt));
        display: flex; align-items: center; justify-content: center;
        font-family: 'Sora', sans-serif; font-weight: 700; font-size: 0.82rem;
        color: #fff; flex-shrink: 0;
        box-shadow: 0 2px 8px rgba(217,119,6,0.45);
    }

    .sb-profile-info { overflow: hidden; transition: opacity var(--transition); }

    .sb-profile-name {
        font-size: 0.82rem; font-weight: 600;
        color: #ffffff;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }

    .sb-profile-role { font-size: 0.68rem; color: var(--sb-text); white-space: nowrap; }

    body.sidebar-collapsed .sb-profile-info { opacity: 0; width: 0; overflow: hidden; }

    /* ── Nav scroll area ──────────────────── */
    .sb-nav {
        flex: 1; overflow-y: auto; overflow-x: hidden;
        padding: 8px 0;
        scrollbar-width: thin;
        scrollbar-color: var(--sb-hover) transparent;
    }

    .sb-nav::-webkit-scrollbar { width: 3px; }
    .sb-nav::-webkit-scrollbar-track { background: transparent; }
    .sb-nav::-webkit-scrollbar-thumb { background: var(--sb-hover); border-radius: 3px; }

    /* ── Section titles ───────────────────── */
    .sb-section-title {
        padding: 13px 20px 4px;
        font-size: 0.68rem; font-weight: 700;
        color: var(--sb-text-header);
        text-transform: uppercase; letter-spacing: 0.12em;
        white-space: nowrap;
        transition: opacity var(--transition);
    }

    body.sidebar-collapsed .sb-section-title { opacity: 0; height: 0; padding: 0; overflow: hidden; }

    /* ── Nav links ────────────────────────── */
    .sb-nav ul { list-style: none; padding: 0; margin: 0; }

    .sb-nav-link {
        display: flex; align-items: center; gap: 12px;
        padding: 10px 17px;
        color: var(--sb-text);
        text-decoration: none;
        cursor: pointer;
        white-space: nowrap;
        position: relative;
        transition: color var(--transition), background var(--transition);
        border: none; background: none;
        width: 100%; text-align: left;
        font-family: 'DM Sans', sans-serif;
    }

    .sb-nav-link:hover {
        background: var(--sb-hover);
        color: #ffffff;
        text-decoration: none;
    }

    .sb-nav-link.active {
        background: var(--sb-active-bg);
        color: #ffffff;
    }

    .sb-nav-link.active::before {
        content: '';
        position: absolute; left: 0; top: 4px; bottom: 4px;
        width: 3px;
        background: var(--sb-active-line);
        border-radius: 0 3px 3px 0;
    }

    .sb-nav-icon {
        width: 20px; text-align: center;
        font-size: 15px; flex-shrink: 0;
    }

    /* .sb-nav-label {
        font-size: 0.845rem; font-weight: 500;
        flex: 1;
        transition: opacity var(--transition);
    } */

    /* cmtan AFTER — adjust font-size to your preference */
    .sb-nav-label {
        font-size: 0.9rem; /* ← change this: 0.8rem=smaller, 1rem=normal, 1.1rem=larger */
        font-weight: 500;
        color: inherit; /* ← inherits from parent sb-nav-link */
        flex: 1;
        transition: opacity var(--transition);
    }

    body.sidebar-collapsed .sb-nav-label,
    body.sidebar-collapsed .sb-badge,
    body.sidebar-collapsed .sb-chevron { opacity: 0; width: 0; overflow: hidden; }

    /* Badges */
    .sb-badge {
        font-size: 0.6rem; font-weight: 700;
        padding: 2px 7px; border-radius: 20px;
        color: #fff; line-height: 1.5;
        transition: opacity var(--transition);
    }

    .sb-badge.badge-blue   { background: var(--accent-lt); }
    .sb-badge.badge-orange { background: var(--gold); }
    .sb-badge.badge-red    { background: var(--clr-danger); }

    .sb-chevron {
        font-size: 10px; color: var(--sb-text-header);
        transition: transform 0.2s, opacity var(--transition);
    }

    .sb-nav-link[aria-expanded="true"] .sb-chevron { transform: rotate(90deg); }

    /* Submenu */
    .sb-submenu {
        list-style: none;
        background: var(--sb-bg-deep);
        overflow: hidden;
    }

    .sb-submenu .sb-nav-link {
        padding: 8px 17px 8px 48px;
        font-size: 0.8rem;
        color: var(--sb-text);
    }

    .sb-submenu .sb-nav-link::before { display: none; }

    .sb-submenu .sb-nav-link.active,
    .sb-submenu .sb-nav-link:hover  { color: #ffffff; }

    /* Collapsed tooltip */
    body.sidebar-collapsed .sb-nav-link { justify-content: center; }
    body.sidebar-collapsed .sb-nav-icon { width: auto; }

    body.sidebar-collapsed .sb-nav-link[data-tooltip]:hover::after {
        content: attr(data-tooltip);
        position: absolute;
        left: calc(var(--sidebar-w-collapsed) + 10px);
        top: 50%; transform: translateY(-50%);
        background: #1e293b; color: #fff;
        padding: 5px 11px; border-radius: 6px;
        font-size: 0.78rem; white-space: nowrap;
        z-index: 9999; pointer-events: none;
        box-shadow: 0 4px 14px rgba(0,0,0,0.3);
        font-family: 'DM Sans', sans-serif;
    }

    /* Sidebar bottom */
    .sb-footer-nav {
        padding: 10px 0 6px;
        border-top: 1px solid var(--sb-border);
        flex-shrink: 0;
    }
</style>

