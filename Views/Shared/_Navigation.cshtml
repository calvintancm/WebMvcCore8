@* ═══════════════════════════════════════════
   _Navigation.cshtml — Left Sidebar
   FIXED: submenu icons always visible
   FIXED: tooltips on all menu + submenu items
   FIXED: collapse/expand works correctly
═══════════════════════════════════════════ *@
<style>

    /* ══════════════════════════════════════════
       SIDEBAR BASE
    ══════════════════════════════════════════ */
    #sidebar {
        position: fixed;
        top: 0; left: 0; bottom: 0;
        width: var(--sidebar-w);
        background: var(--sb-bg);
        display: flex; flex-direction: column;
        z-index: 1040;
        transition: width var(--transition);
        overflow: hidden;
    }

    body.sidebar-collapsed #sidebar { width: var(--sidebar-w-collapsed); }

    /* ── Brand ────────────────────────────────────────────── */
    .sb-brand {
        display: flex; align-items: center; gap: 12px;
        padding: 0 17px; height: var(--topbar-h);
        background: var(--sb-bg-top);
        border-bottom: 1px solid var(--sb-border);
        flex-shrink: 0; text-decoration: none; overflow: hidden;
    }

    .sb-brand-icon {
        width: 36px; height: 36px;
        background: linear-gradient(135deg, #3b96e8, #7ec8f0);
        border-radius: 9px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 4px 12px rgba(59,150,232,0.45);
    }

    .sb-brand-icon i { color: #fff; font-size: 17px; }

    .sb-brand-text {
        overflow: hidden;
        transition: opacity var(--transition), width var(--transition);
        white-space: nowrap;
    }

    .sb-brand-name {
        font-family: 'Sora', sans-serif; font-size: 0.95rem;
        font-weight: 700; color: #fff; line-height: 1.2;
    }

    .sb-brand-sub { font-size: 0.67rem; color: var(--sb-text); letter-spacing: 0.04em; }

    body.sidebar-collapsed .sb-brand-text { opacity: 0; width: 0; }

    /* ── Scroll area ─────────────────────────────────────── */
    .sb-nav {
        flex: 1; overflow-y: auto; overflow-x: hidden;
        padding: 8px 0;
        scrollbar-width: thin;
        scrollbar-color: var(--sb-hover) transparent;
    }

    .sb-nav::-webkit-scrollbar       { width: 3px; }
    .sb-nav::-webkit-scrollbar-track { background: transparent; }
    .sb-nav::-webkit-scrollbar-thumb { background: var(--sb-hover); border-radius: 3px; }

    .sb-nav ul { list-style: none; padding: 0; margin: 0; }

    /* ── Section titles ──────────────────────────────────── */
    .sb-section-title {
        padding: 13px 20px 4px;
        font-size: 0.68rem; font-weight: 700;
        color: var(--sb-text-header);
        text-transform: uppercase; letter-spacing: 0.12em;
        white-space: nowrap;
        transition: opacity var(--transition), height var(--transition), padding var(--transition);
    }

    body.sidebar-collapsed .sb-section-title {
        opacity: 0; height: 0;
        padding-top: 0; padding-bottom: 0;
        overflow: hidden;
    }

    /* ══════════════════════════════════════════
       NAV LINK — shared base for ALL levels
    ══════════════════════════════════════════ */
    .sb-nav-link {
        display: flex; align-items: center; gap: 11px;
        padding: 10px 17px;
        color: var(--sb-text); text-decoration: none;
        cursor: pointer; white-space: nowrap; position: relative;
        transition: color var(--transition), background var(--transition);
        border: none; background: none;
        width: 100%; text-align: left;
        font-family: 'DM Sans', sans-serif;
    }

    .sb-nav-link:hover { background: var(--sb-hover); color: #fff; text-decoration: none; }

    .sb-nav-link.active { background: var(--sb-active-bg); color: #fff; }

    .sb-nav-link.active::before {
        content: ''; position: absolute; left: 0; top: 5px; bottom: 5px;
        width: 3px; background: var(--sb-active-line); border-radius: 0 3px 3px 0;
    }

    /* ══════════════════════════════════════════
       ICON — fixed width, consistent all levels
    ══════════════════════════════════════════ */
    .sb-nav-icon {
        width: 22px !important;
        min-width: 22px !important;
        text-align: center; font-size: 15px;
        flex-shrink: 0 !important;
        display: flex !important;
        align-items: center; justify-content: center;
        visibility: visible !important;
        opacity: 1;
    }

    /* ── Label ──────────────────────────────────────────── */
    .sb-nav-label {
        font-size: 0.9rem; font-weight: 500;
        flex: 1; color: inherit;
        transition: opacity var(--transition), width var(--transition), max-width var(--transition);
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }

    /* ── Badges ─────────────────────────────────────────── */
    .sb-badge {
        font-size: 0.6rem; font-weight: 700;
        padding: 2px 7px; border-radius: 20px;
        color: #fff; line-height: 1.5; flex-shrink: 0;
        transition: opacity var(--transition), width var(--transition);
    }

    .sb-badge.badge-blue   { background: var(--accent-lt); }
    .sb-badge.badge-orange { background: var(--gold); }
    .sb-badge.badge-red    { background: var(--clr-danger); }

    /* ── Chevron ────────────────────────────────────────── */
    .sb-chevron {
        font-size: 10px; color: var(--sb-text-header); flex-shrink: 0;
        transition: transform 0.22s, opacity var(--transition), width var(--transition);
    }

    .sb-nav-link[aria-expanded="true"] .sb-chevron { transform: rotate(90deg); }

    /* ══════════════════════════════════════════
       COLLAPSED STATE
       Only hide TEXT elements — never icons
    ══════════════════════════════════════════ */
    body.sidebar-collapsed .sb-nav-label {
        opacity: 0; width: 0; max-width: 0; overflow: hidden; pointer-events: none;
    }

    body.sidebar-collapsed .sb-badge {
        opacity: 0; width: 0; overflow: hidden; pointer-events: none;
    }

    body.sidebar-collapsed .sb-chevron {
        opacity: 0; width: 0; overflow: hidden; pointer-events: none;
    }

    body.sidebar-collapsed .sb-nav-link {
        justify-content: center; padding: 10px 0;
    }

    /* Icons get slightly larger when collapsed */
    body.sidebar-collapsed .sb-nav-icon {
        width: 22px !important; min-width: 22px !important;
        font-size: 18px;
    }

    /* Submenus hidden when collapsed */
    body.sidebar-collapsed .sb-submenu {
        display: none !important;
    }

    /* ══════════════════════════════════════════
       SUBMENU
    ══════════════════════════════════════════ */
    .sb-submenu {
        list-style: none; margin: 0; padding: 3px 0;
        background: var(--sb-bg-deep);
        border-left: 2px solid rgba(255,255,255,0.08);
        margin-left: 28px;
        overflow: hidden;
    }

    /* Submenu link — same structure as parent */
    .sb-submenu .sb-nav-link {
        padding: 8px 14px 8px 10px;
        font-size: 0.845rem; opacity: 0.9; gap: 9px;
    }

    .sb-submenu .sb-nav-link:hover  { opacity: 1; color: #fff; }
    .sb-submenu .sb-nav-link.active { opacity: 1; background: rgba(255,255,255,0.09); }
    .sb-submenu .sb-nav-link.active::before { display: none; }

    /* Submenu icon — slightly smaller but ALWAYS visible */
    .sb-submenu .sb-nav-icon {
        width: 18px !important; min-width: 18px !important;
        font-size: 13px; opacity: 0.8;
        color: var(--sb-text);
        display: flex !important; visibility: visible !important;
        flex-shrink: 0 !important;
    }

    .sb-submenu .sb-nav-link:hover  .sb-nav-icon,
    .sb-submenu .sb-nav-link.active .sb-nav-icon {
        opacity: 1; color: var(--sb-active-line);
    }

    /* Submenu label */
    .sb-submenu .sb-nav-label {
        font-size: 0.835rem; font-weight: 400; padding-left: 1px;
    }

    .sb-submenu .sb-nav-link.active .sb-nav-label { font-weight: 600; }

    /* ══════════════════════════════════════════
       TOOLTIPS — shown on collapsed main items
       AND on ALL submenu items (always useful)
    ══════════════════════════════════════════ */

    /* Tooltip base — used for collapsed main items */
    body.sidebar-collapsed [data-ptc-tooltip] {
        position: relative;
    }

    body.sidebar-collapsed [data-ptc-tooltip]:hover::after {
        content: attr(data-ptc-tooltip);
        position: absolute;
        left: calc(var(--sidebar-w-collapsed) + 10px);
        top: 50%; transform: translateY(-50%);
        background: #1a2535; color: #f0f6ff;
        padding: 5px 12px; border-radius: 7px;
        font-size: 0.78rem; white-space: nowrap;
        z-index: 9999; pointer-events: none;
        box-shadow: 0 4px 16px rgba(0,0,0,0.35);
        font-family: 'DM Sans', sans-serif;
        font-weight: 500;
        letter-spacing: 0.01em;
        border: 1px solid rgba(255,255,255,0.08);
    }

    /* Arrow pointer for tooltip */
    body.sidebar-collapsed [data-ptc-tooltip]:hover::before {
        content: '';
        position: absolute;
        left: calc(var(--sidebar-w-collapsed) + 4px);
        top: 50%; transform: translateY(-50%);
        border: 5px solid transparent;
        border-right-color: #1a2535;
        z-index: 9999; pointer-events: none;
    }

    /* Submenu items — tooltip always visible (not just collapsed) */
    .sb-submenu [data-ptc-tooltip] { position: relative; }

    .sb-submenu [data-ptc-tooltip]:hover::after {
        content: attr(data-ptc-tooltip);
        position: absolute;
        left: 100%; top: 50%; transform: translateY(-50%);
        margin-left: 10px;
        background: #1a2535; color: #f0f6ff;
        padding: 4px 10px; border-radius: 6px;
        font-size: 0.75rem; white-space: nowrap;
        z-index: 9999; pointer-events: none;
        box-shadow: 0 3px 12px rgba(0,0,0,0.3);
        font-family: 'DM Sans', sans-serif;
        border: 1px solid rgba(255,255,255,0.08);
    }

    /* ── Sidebar footer ──────────────────────────────────── */
    .sb-footer-nav {
        padding: 8px 0 6px;
        border-top: 1px solid var(--sb-border);
        flex-shrink: 0;
    }

    /* ══════════════════════════════════════════
       MOBILE
    ══════════════════════════════════════════ */
    @@media (max-width: 768px) {
        #sidebar {
            width: var(--sidebar-w) !important;
            transform: translateX(-100%);
            transition: transform var(--transition);
            z-index: 1050;
            box-shadow: 4px 0 24px rgba(0,0,0,0.4);
        }

        body.mobile-open #sidebar { transform: translateX(0); }

        /* When open on mobile restore ALL text */
        body.mobile-open .sb-brand-text,
        body.mobile-open .sb-nav-label,
        body.mobile-open .sb-badge,
        body.mobile-open .sb-chevron,
        body.mobile-open .sb-section-title {
            opacity: 1 !important;
            width: auto !important;
            max-width: none !important;
            overflow: visible !important;
        }

        body.mobile-open .sb-nav-link {
            justify-content: flex-start !important;
            padding: 10px 17px !important;
        }

        body.mobile-open .sb-nav-icon {
            font-size: 15px !important;
            width: 22px !important;
            min-width: 22px !important;
        }

        body.mobile-open .sb-submenu { display: block !important; }
    }
</style>

