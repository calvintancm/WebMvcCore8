@* ═══════════════════════════════════════════
   _Navigation.cshtml — Left Sidebar
   - Submenu items now show icons
   - Connector line shows hierarchy
═══════════════════════════════════════════ *@
<style>
    #sidebar {
        position: fixed;
        top: 0; left: 0; bottom: 0;
        width: var(--sidebar-w);
        background: var(--sb-bg);
        display: flex; flex-direction: column;
        z-index: 1040;
        transition: width var(--transition);
        overflow: hidden;
    }

    body.sidebar-collapsed #sidebar { width: var(--sidebar-w-collapsed); }

    /* ── Brand ─────────────────────────────── */
    .sb-brand {
        display: flex; align-items: center; gap: 12px;
        padding: 0 17px; height: var(--topbar-h);
        background: var(--sb-bg-top);
        border-bottom: 1px solid var(--sb-border);
        flex-shrink: 0; text-decoration: none; overflow: hidden;
    }

    .sb-brand-icon {
        width: 36px; height: 36px;
        background: linear-gradient(135deg, #3b96e8, #7ec8f0);
        border-radius: 9px;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
        box-shadow: 0 4px 12px rgba(59,150,232,0.45);
    }

    .sb-brand-icon i { color: #fff; font-size: 17px; }

    .sb-brand-text { overflow: hidden; transition: opacity var(--transition), width var(--transition); }
    .sb-brand-name { font-family: 'Sora', sans-serif; font-size: 0.95rem; font-weight: 700; color: #fff; white-space: nowrap; line-height: 1.2; }
    .sb-brand-sub  { font-size: 0.67rem; color: var(--sb-text); white-space: nowrap; letter-spacing: 0.04em; }
    body.sidebar-collapsed .sb-brand-text { opacity: 0; width: 0; }

    /* ── Scroll area ───────────────────────── */
    .sb-nav { flex: 1; overflow-y: auto; overflow-x: hidden; padding: 8px 0; scrollbar-width: thin; scrollbar-color: var(--sb-hover) transparent; }
    .sb-nav::-webkit-scrollbar       { width: 3px; }
    .sb-nav::-webkit-scrollbar-track { background: transparent; }
    .sb-nav::-webkit-scrollbar-thumb { background: var(--sb-hover); border-radius: 3px; }

    /* ── Section titles ────────────────────── */
    .sb-section-title {
        padding: 13px 20px 4px;
        font-size: 0.68rem; font-weight: 700;
        color: var(--sb-text-header);
        text-transform: uppercase; letter-spacing: 0.12em;
        white-space: nowrap;
        transition: opacity var(--transition), height var(--transition), padding var(--transition);
    }
    body.sidebar-collapsed .sb-section-title { opacity: 0; height: 0; padding-top: 0; padding-bottom: 0; overflow: hidden; }

    .sb-nav ul { list-style: none; padding: 0; margin: 0; }

    /* ── Nav link base — shared by ALL items ── */
    .sb-nav-link {
        display: flex; align-items: center; gap: 11px;
        padding: 10px 17px;
        color: var(--sb-text);
        text-decoration: none; cursor: pointer;
        white-space: nowrap; position: relative;
        transition: color var(--transition), background var(--transition);
        border: none; background: none; width: 100%; text-align: left;
        font-family: 'DM Sans', sans-serif;
    }

    .sb-nav-link:hover { background: var(--sb-hover); color: #fff; text-decoration: none; }

    .sb-nav-link.active { background: var(--sb-active-bg); color: #fff; }

    .sb-nav-link.active::before {
        content: ''; position: absolute; left: 0; top: 5px; bottom: 5px;
        width: 3px; background: var(--sb-active-line); border-radius: 0 3px 3px 0;
    }

    /* ── Icon — fixed width, same on all levels ── */
    .sb-nav-icon {
        width: 22px; min-width: 22px;
        text-align: center; font-size: 15px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
    }

    /* ── Label ──────────────────────────────── */
    .sb-nav-label {
        font-size: 0.9rem; font-weight: 500;
        flex: 1; color: inherit;
        transition: opacity var(--transition);
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }

    /* ── Badges ─────────────────────────────── */
    .sb-badge { font-size: 0.6rem; font-weight: 700; padding: 2px 7px; border-radius: 20px; color: #fff; line-height: 1.5; transition: opacity var(--transition); flex-shrink: 0; }
    .sb-badge.badge-blue   { background: var(--accent-lt); }
    .sb-badge.badge-orange { background: var(--gold); }
    .sb-badge.badge-red    { background: var(--clr-danger); }

    /* ── Chevron ─────────────────────────────── */
    .sb-chevron { font-size: 10px; color: var(--sb-text-header); transition: transform 0.2s, opacity var(--transition); flex-shrink: 0; }
    .sb-nav-link[aria-expanded="true"] .sb-chevron { transform: rotate(90deg); }

    /* ── Collapsed state ─────────────────────── */
    body.sidebar-collapsed .sb-nav-label,
    body.sidebar-collapsed .sb-badge,
    body.sidebar-collapsed .sb-chevron { opacity: 0; width: 0; overflow: hidden; pointer-events: none; }
    body.sidebar-collapsed .sb-nav-link { justify-content: center; padding: 10px; }
    body.sidebar-collapsed .sb-nav-icon { width: auto; font-size: 17px; }
    body.sidebar-collapsed .sb-submenu  { display: none !important; }

    /* ══════════════════════════════════════════
       SUBMENU STYLES — FIXED
    ══════════════════════════════════════════ */

    .sb-submenu {
        list-style: none;
        background: var(--sb-bg-deep);
        overflow: hidden;
        margin: 0;
        padding: 2px 0;
        border-left: 2px solid rgba(255,255,255,0.07);
        margin-left: 27px;
    }

        /* Submenu item link */
        .sb-submenu .sb-nav-link {
            padding: 8px 17px 8px 12px; /* ← left padding for icon breathing room */
            font-size: 0.84rem;
            opacity: 0.88;
            gap: 10px;
        }

            .sb-submenu .sb-nav-link:hover {
                opacity: 1;
                color: #fff;
            }

            .sb-submenu .sb-nav-link.active {
                opacity: 1;
                background: rgba(255,255,255,0.08);
            }

                .sb-submenu .sb-nav-link.active::before {
                    display: none;
                }

        /* ── Submenu icon — FIXED: force always visible ── */
        .sb-submenu .sb-nav-icon {
            font-size: 13px;
            opacity: 0.75;
            color: var(--sb-text);
            width: 18px !important; /* ← never collapse to 0 */
            min-width: 18px !important; /* ← never collapse to 0 */
            display: flex !important; /* ← always show */
            flex-shrink: 0 !important;
            visibility: visible !important;
        }

        .sb-submenu .sb-nav-link:hover .sb-nav-icon,
        .sb-submenu .sb-nav-link.active .sb-nav-icon {
            opacity: 1;
            color: var(--sb-active-line);
        }

        /* Submenu label */
        .sb-submenu .sb-nav-label {
            font-size: 0.835rem;
            font-weight: 400;
            padding-left: 2px;
        }

        .sb-submenu .sb-nav-link.active .sb-nav-label {
            font-weight: 600;
        }

    /* ── Collapsed tooltip ───────────────────── */
    body.sidebar-collapsed .sb-nav-link[data-tooltip] { position: relative; }
    body.sidebar-collapsed .sb-nav-link[data-tooltip]:hover::after {
        content: attr(data-tooltip);
        position: absolute; left: calc(var(--sidebar-w-collapsed) + 10px);
        top: 50%; transform: translateY(-50%);
        background: #1e293b; color: #fff;
        padding: 5px 12px; border-radius: 7px;
        font-size: 0.78rem; white-space: nowrap;
        z-index: 9999; pointer-events: none;
        box-shadow: 0 4px 16px rgba(0,0,0,0.3);
        font-family: 'DM Sans', sans-serif;
        /* clear the submenu connector override */
        border-left: none; margin-left: 0;
    }

    /* ── Sidebar footer ──────────────────────── */
    .sb-footer-nav { padding: 8px 0 6px; border-top: 1px solid var(--sb-border); flex-shrink: 0; }

    /* ── Mobile ──────────────────────────────── */
    @@media (max-width: 768px) {
        #sidebar { width: var(--sidebar-w) !important; transform: translateX(-100%); transition: transform var(--transition); z-index: 1050; box-shadow: 4px 0 24px rgba(0,0,0,0.35); }
        body.mobile-open #sidebar { transform: translateX(0); }
        body.mobile-open .sb-brand-text,
        body.mobile-open .sb-nav-label,
        body.mobile-open .sb-badge,
        body.mobile-open .sb-chevron,
        body.mobile-open .sb-section-title { opacity: 1 !important; width: auto !important; overflow: visible !important; }
        body.mobile-open .sb-nav-link { justify-content: flex-start !important; padding: 10px 17px !important; }
        body.mobile-open .sb-nav-icon { font-size: 15px !important; width: 22px !important; }
        body.mobile-open .sb-submenu  { display: block !important; }
    }
</style>

