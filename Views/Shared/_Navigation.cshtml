@* ═══════════════════════════════════════════
   _Navigation.cshtml — Left Sidebar
   FIXED: submenu icons always visible after collapse toggle
   FIXED: Sign Out calls KSwal safely after scripts load
═══════════════════════════════════════════ *@
<style>

    /* ══════════════════════════════════════════
       SIDEBAR BASE
    ══════════════════════════════════════════ */
    #sidebar {
        position: fixed;
        top: 0; left: 0; bottom: 0;
        width: var(--sidebar-w);
        background: var(--sb-bg);
        display: flex; flex-direction: column;
        z-index: 1040;
        transition: width var(--transition);
        overflow: hidden;
    }

    body.sidebar-collapsed #sidebar { width: var(--sidebar-w-collapsed); }

    /* ── Brand ─────────────────────────────── */
    .sb-brand {
        display: flex; align-items: center; gap: 12px;
        padding: 0 17px; height: var(--topbar-h);
        background: var(--sb-bg-top);
        border-bottom: 1px solid var(--sb-border);
        flex-shrink: 0; text-decoration: none; overflow: hidden;
    }

    .sb-brand-icon {
        width: 36px; height: 36px;
        background: linear-gradient(135deg, #3b96e8, #7ec8f0);
        border-radius: 9px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 4px 12px rgba(59,150,232,0.45);
    }

    .sb-brand-icon i { color: #fff; font-size: 17px; }

    .sb-brand-text {
        overflow: hidden;
        transition: opacity var(--transition), max-width var(--transition);
        white-space: nowrap; max-width: 200px;
    }

    .sb-brand-name {
        font-family: 'Sora', sans-serif; font-size: 0.95rem;
        font-weight: 700; color: #fff; line-height: 1.2;
    }

    .sb-brand-sub { font-size: 0.67rem; color: var(--sb-text); letter-spacing: 0.04em; }

    body.sidebar-collapsed .sb-brand-text { opacity: 0; max-width: 0; }

    /* ── Scroll area ────────────────────────── */
    .sb-nav {
        flex: 1; overflow-y: auto; overflow-x: hidden;
        padding: 8px 0;
        scrollbar-width: thin;
        scrollbar-color: var(--sb-hover) transparent;
    }

    .sb-nav::-webkit-scrollbar       { width: 3px; }
    .sb-nav::-webkit-scrollbar-track { background: transparent; }
    .sb-nav::-webkit-scrollbar-thumb { background: var(--sb-hover); border-radius: 3px; }
    .sb-nav ul { list-style: none; padding: 0; margin: 0; }

    /* ── Section titles ─────────────────────── */
    .sb-section-title {
        padding: 13px 20px 4px;
        font-size: 0.68rem; font-weight: 700;
        color: var(--sb-text-header);
        text-transform: uppercase; letter-spacing: 0.12em;
        white-space: nowrap;
        transition: opacity var(--transition), max-height var(--transition), padding var(--transition);
        max-height: 40px; overflow: hidden;
    }

    body.sidebar-collapsed .sb-section-title {
        opacity: 0; max-height: 0; padding-top: 0; padding-bottom: 0;
    }

    /* ══════════════════════════════════════════
       NAV LINK BASE
    ══════════════════════════════════════════ */
    .sb-nav-link {
        display: flex; align-items: center; gap: 11px;
        padding: 10px 17px;
        color: var(--sb-text); text-decoration: none;
        cursor: pointer; white-space: nowrap; position: relative;
        transition: color var(--transition), background var(--transition);
        border: none; background: none;
        width: 100%; text-align: left;
        font-family: 'DM Sans', sans-serif;
    }

    .sb-nav-link:hover      { background: var(--sb-hover); color: #fff; text-decoration: none; }
    .sb-nav-link.active     { background: var(--sb-active-bg); color: #fff; }

    .sb-nav-link.active::before {
        content: ''; position: absolute; left: 0; top: 5px; bottom: 5px;
        width: 3px; background: var(--sb-active-line); border-radius: 0 3px 3px 0;
    }

    /* ══════════════════════════════════════════
       ICONS
       Rule: icons are NEVER hidden — only labels,
       badges and chevrons collapse.
    ══════════════════════════════════════════ */
    .sb-nav-icon {
        /* Fixed dimensions — flex cannot shrink this */
        width: 22px;
        min-width: 22px;
        flex-shrink: 0;
        font-size: 15px;
        text-align: center;
        display: flex;
        align-items: center;
        justify-content: center;
        /* Permanently visible */
        opacity: 1;
        visibility: visible;
        overflow: visible;
    }

    /* ── Labels, badges, chevrons ───────────── */
    .sb-nav-label {
        font-size: 0.9rem; font-weight: 500;
        flex: 1; color: inherit;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        transition: opacity var(--transition), max-width var(--transition);
        max-width: 200px;
    }

    .sb-badge {
        font-size: 0.6rem; font-weight: 700;
        padding: 2px 7px; border-radius: 20px;
        color: #fff; line-height: 1.5; flex-shrink: 0;
        transition: opacity var(--transition), max-width var(--transition);
        overflow: hidden; max-width: 60px;
    }

    .sb-badge.badge-blue   { background: var(--accent-lt); }
    .sb-badge.badge-orange { background: var(--gold); }
    .sb-badge.badge-red    { background: var(--clr-danger); }

    .sb-chevron {
        font-size: 10px; color: var(--sb-text-header); flex-shrink: 0;
        overflow: hidden; max-width: 20px;
        transition: transform 0.22s, opacity var(--transition), max-width var(--transition);
    }

    .sb-nav-link[aria-expanded="true"] .sb-chevron { transform: rotate(90deg); }

    /* ══════════════════════════════════════════
       COLLAPSED STATE
       ONLY touch labels / badges / chevrons.
       Do NOT touch .sb-nav-icon at all.
    ══════════════════════════════════════════ */
    body.sidebar-collapsed .sb-nav-label,
    body.sidebar-collapsed .sb-badge,
    body.sidebar-collapsed .sb-chevron {
        opacity: 0;
        max-width: 0;
        pointer-events: none;
    }

    /* Center the link around its icon */
    body.sidebar-collapsed .sb-nav > ul > li > .sb-nav-link,
    body.sidebar-collapsed .sb-footer-nav .sb-nav-link {
        justify-content: center;
        padding: 10px 0;
        gap: 0;
    }

    /* Icon slightly larger on collapsed rail — TOP LEVEL ONLY */
    body.sidebar-collapsed .sb-nav > ul > li > .sb-nav-link .sb-nav-icon,
    body.sidebar-collapsed .sb-footer-nav .sb-nav-link .sb-nav-icon {
        font-size: 18px;
        width: 22px;
        min-width: 22px;
    }

    /* ── Submenus hidden when sidebar collapsed ── */
    body.sidebar-collapsed .sb-submenu { display: none !important; }

    /* ══════════════════════════════════════════
       SUBMENU
    ══════════════════════════════════════════ */
    .sb-submenu {
        list-style: none; margin: 0; padding: 3px 0;
        background: var(--sb-bg-deep);
        border-left: 2px solid rgba(255,255,255,0.08);
        margin-left: 28px;
        overflow: hidden;
    }

    .sb-submenu .sb-nav-link {
        padding: 8px 14px 8px 10px;
        font-size: 0.845rem; opacity: 0.9; gap: 9px;
    }

    .sb-submenu .sb-nav-link:hover  { opacity: 1; color: #fff; }
    .sb-submenu .sb-nav-link.active { opacity: 1; background: rgba(255,255,255,0.09); }
    .sb-submenu .sb-nav-link.active::before { display: none; }

    /*
     * SUBMENU ICONS — explicit, high-specificity block.
     * These must NEVER be overridden by collapsed-state rules
     * because the entire submenu is hidden when collapsed anyway.
     */
    .sb-submenu .sb-nav-link .sb-nav-icon {
        width: 18px !important;
        min-width: 18px !important;
        font-size: 13px !important;
        opacity: 1 !important;
        visibility: visible !important;
        overflow: visible !important;
        flex-shrink: 0 !important;
        color: var(--sb-text);
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
    }

    .sb-submenu .sb-nav-link:hover  .sb-nav-icon,
    .sb-submenu .sb-nav-link.active .sb-nav-icon {
        color: var(--sb-active-line);
        opacity: 1 !important;
    }

    /* Submenu labels are always fully visible (submenu hidden on collapse anyway) */
    .sb-submenu .sb-nav-link .sb-nav-label {
        font-size: 0.835rem; font-weight: 400;
        opacity: 1 !important;
        max-width: 200px !important;
        overflow: hidden;
    }

    .sb-submenu .sb-nav-link.active .sb-nav-label { font-weight: 600; }

    /* ══════════════════════════════════════════
       TOOLTIPS (collapsed sidebar, top-level only)
    ══════════════════════════════════════════ */
    body.sidebar-collapsed [data-ptc-tooltip] { position: relative; }

    body.sidebar-collapsed [data-ptc-tooltip]:hover::after {
        content: attr(data-ptc-tooltip);
        position: absolute;
        left: calc(var(--sidebar-w-collapsed) + 10px);
        top: 50%; transform: translateY(-50%);
        background: #1a2535; color: #f0f6ff;
        padding: 5px 12px; border-radius: 7px;
        font-size: 0.78rem; white-space: nowrap;
        z-index: 9999; pointer-events: none;
        box-shadow: 0 4px 16px rgba(0,0,0,0.35);
        font-family: 'DM Sans', sans-serif;
        font-weight: 500; letter-spacing: 0.01em;
        border: 1px solid rgba(255,255,255,0.08);
    }

    body.sidebar-collapsed [data-ptc-tooltip]:hover::before {
        content: '';
        position: absolute;
        left: calc(var(--sidebar-w-collapsed) + 4px);
        top: 50%; transform: translateY(-50%);
        border: 5px solid transparent;
        border-right-color: #1a2535;
        z-index: 9999; pointer-events: none;
    }

    /* ── Sidebar footer ─────────────────────── */
    .sb-footer-nav {
        padding: 8px 0 6px;
        border-top: 1px solid var(--sb-border);
        flex-shrink: 0;
    }

    /* ══════════════════════════════════════════
       MOBILE
    ══════════════════════════════════════════ */
    @@media (max-width: 768px) {
        #sidebar {
            width: var(--sidebar-w) !important;
            transform: translateX(-100%);
            transition: transform var(--transition);
            z-index: 1050;
            box-shadow: 4px 0 24px rgba(0,0,0,0.4);
        }

        body.mobile-open #sidebar { transform: translateX(0); }

        body.mobile-open .sb-brand-text,
        body.mobile-open .sb-nav-label,
        body.mobile-open .sb-badge,
        body.mobile-open .sb-chevron,
        body.mobile-open .sb-section-title {
            opacity: 1 !important;
            max-width: 200px !important;
            overflow: visible !important;
        }

        body.mobile-open .sb-nav > ul > li > .sb-nav-link,
        body.mobile-open .sb-footer-nav .sb-nav-link {
            justify-content: flex-start !important;
            padding: 10px 17px !important;
            gap: 11px !important;
        }

        body.mobile-open .sb-nav > ul > li > .sb-nav-link .sb-nav-icon,
        body.mobile-open .sb-footer-nav .sb-nav-link .sb-nav-icon {
            font-size: 15px !important;
            width: 22px !important;
            min-width: 22px !important;
        }

        body.mobile-open .sb-submenu { display: block !important; }
    }
</style>

