        <button class="sb-nav-link" data-ptc-tooltip="Sign Out" id="btnSidebarSignOut">
            <span class="sb-nav-icon"><i class="bi bi-box-arrow-left"></i></span>
            <span class="sb-nav-label">Sign Out</span>
        </button>
    </div>

</nav>

<script>
    (function () {
        document.addEventListener('DOMContentLoaded', function () {

            var body     = document.body;
            var submenus = document.querySelectorAll('.sb-submenu');

            /* ── Track open submenus so we can restore them ── */
            var openSubmenuIds = [];

            function hideAllSubmenus() {
                openSubmenuIds = [];
                submenus.forEach(function (sm) {
                    if (sm.classList.contains('show')) {
                        openSubmenuIds.push(sm.id);
                    }
                    sm.classList.remove('show');
                    var btn = document.querySelector('[data-bs-target="#' + sm.id + '"]');
                    if (btn) btn.setAttribute('aria-expanded', 'false');
                });
            }

            function restoreSubmenus() {
                submenus.forEach(function (sm) {
                    if (openSubmenuIds.indexOf(sm.id) !== -1) {
                        sm.classList.add('show');
                        var btn = document.querySelector('[data-bs-target="#' + sm.id + '"]');
                        if (btn) btn.setAttribute('aria-expanded', 'true');
                    }
                });
            }

            /* ── Position flyout vertically when shown ── */
            function positionFlyouts() {
                document.querySelectorAll('.has-submenu').forEach(function (li) {
                    var flyout = li.querySelector('.sb-flyout');
                    if (!flyout) return;

                    li.addEventListener('mouseenter', function () {
                        if (!body.classList.contains('sidebar-collapsed')) return;
                        var rect = li.getBoundingClientRect();
                        flyout.style.top = rect.top + 'px';
                    });
                });
            }

            positionFlyouts();

            /* ── Watch sidebar collapse/expand ── */
            var wasCollapsed = body.classList.contains('sidebar-collapsed');

            var observer = new MutationObserver(function () {
                var isCollapsed = body.classList.contains('sidebar-collapsed');

                if (isCollapsed && !wasCollapsed) {
                    hideAllSubmenus();
                }

                if (!isCollapsed && wasCollapsed) {
                    restoreSubmenus();
                }

                wasCollapsed = isCollapsed;
            });

            observer.observe(body, { attributes: true, attributeFilter: ['class'] });

            if (body.classList.contains('sidebar-collapsed')) {
                hideAllSubmenus();
            }

            /* ── Sign Out button ── */
            var signOutBtn = document.getElementById('btnSidebarSignOut');
            if (signOutBtn) {
                signOutBtn.addEventListener('click', function () {
                    KSwal.confirm(
                        'Sign Out?',
                        'You will be signed out of the PTC IGH System.',
                        function () { document.getElementById('logoutForm').submit(); }
                    );
                });
            }

        });
    }());
</script>
