<script>
(function () {
    document.addEventListener('DOMContentLoaded', function () {

        var body     = document.body;
        var submenus = document.querySelectorAll('.sb-submenu');

        /* ══════════════════════════════════════════════════════
           KEY FIX:
           Save which submenus were OPEN before collapsing
           so we can restore them exactly when expanding.
           
           Before: hideAll() removed 'show' class
                   showAll() did nothing → Bootstrap had
                   no 'show' class → click on parent did nothing
           
           After:  Save open submenu IDs before hiding
                   Restore 'show' class on those IDs when expanding
        ══════════════════════════════════════════════════════ */
        var openSubmenuIds = [];   /* stores IDs of open submenus */

        function hideAllSubmenus() {
            /* Save which ones are currently open */
            openSubmenuIds = [];
            submenus.forEach(function (sm) {
                if (sm.classList.contains('show')) {
                    openSubmenuIds.push(sm.id);   /* remember this was open */
                }
                /* Force hide — works in Firefox + Chrome */
                sm.classList.remove('show');
                sm.style.display  = 'none';
                sm.style.height   = '';
                sm.style.overflow = 'hidden';

                /* Reset toggle button */
                var btn = document.querySelector('[data-bs-target="#' + sm.id + '"]');
                if (btn) { btn.setAttribute('aria-expanded', 'false'); }
            });
        }

        function restoreSubmenus() {
            submenus.forEach(function (sm) {
                /* Clear inline styles we set */
                sm.style.display  = '';
                sm.style.height   = '';
                sm.style.overflow = '';

                /* Restore 'show' class if it was open before collapse */
                if (openSubmenuIds.indexOf(sm.id) !== -1) {
                    sm.classList.add('show');
                    /* Restore toggle button state */
                    var btn = document.querySelector('[data-bs-target="#' + sm.id + '"]');
                    if (btn) { btn.setAttribute('aria-expanded', 'true'); }
                }
            });
        }

        /* Watch body class changes via MutationObserver */
        var wasCollapsed = body.classList.contains('sidebar-collapsed');

        var observer = new MutationObserver(function () {
            var isCollapsed = body.classList.contains('sidebar-collapsed');

            if (isCollapsed && !wasCollapsed) {
                /* Just collapsed → hide submenus + save state */
                hideAllSubmenus();
            }

            if (!isCollapsed && wasCollapsed) {
                /* Just expanded → restore saved state */
                restoreSubmenus();
            }

            wasCollapsed = isCollapsed;
        });

        observer.observe(body, { attributes: true, attributeFilter: ['class'] });

        /* Run on page load if already collapsed */
        if (body.classList.contains('sidebar-collapsed')) {
            hideAllSubmenus();
        }

        /* Sign Out button */
        var signOutBtn = document.getElementById('btnSidebarSignOut');
        if (signOutBtn) {
            signOutBtn.addEventListener('click', function () {
                KSwal.confirm(
                    'Sign Out?',
                    'You will be signed out of the PTC IGH System.',
                    function () { document.getElementById('logoutForm').submit(); }
                );
            });
        }

    });
}());
</script>
