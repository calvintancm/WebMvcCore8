@{
    ViewData["Title"] = "Leave Transaction";
    ViewData["BreadcrumbSection"] = "IGH Management";
    ViewData["BreadcrumbPage"] = "Leave Transaction";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Leave Transaction</h1>
        <p class="page-subtitle">Driver Leave Records Management</p>
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap;">
        <button class="btn-ptc-primary" onclick="openAddLeaveModal()">
            <i class="bi bi-plus-lg"></i> Add Leave
        </button>
        <button class="btn-ptc-outline" onclick="exportLeaveGrid()">
            <i class="bi bi-download"></i> Export
        </button>
    </div>
</div>

@* ── Filter Card ── *@
<div class="ptc-card mb-3">
    <div class="ptc-card-body" style="padding:16px 20px;">
        <div style="display:flex;flex-wrap:wrap;align-items:flex-end;gap:14px;">

            <div style="display:flex;flex-direction:column;gap:5px;min-width:160px;">
                <label style="font-size:0.75rem;font-weight:600;color:var(--text-muted);
                               text-transform:uppercase;letter-spacing:0.06em;">Month</label>
                <select id="queryLeaveMonth" style="width:160px;"></select>
            </div>

            <div style="display:flex;flex-direction:column;gap:5px;min-width:120px;">
                <label style="font-size:0.75rem;font-weight:600;color:var(--text-muted);
                               text-transform:uppercase;letter-spacing:0.06em;">Year</label>
                <select id="queryLeaveYear" style="width:120px;"></select>
            </div>

            <div style="display:flex;flex-direction:column;gap:5px;flex:1;min-width:200px;">
                <label style="font-size:0.75rem;font-weight:600;color:var(--text-muted);
                               text-transform:uppercase;letter-spacing:0.06em;">Driver Name</label>
                <input type="text" id="queryDriverName"
                       class="k-textbox"
                       style="width:100%;max-width:280px;"
                       placeholder="Search driver name..." />
            </div>

            <div style="display:flex;gap:8px;padding-bottom:1px;">
                <button class="btn-ptc-primary" onclick="refreshLeaveGrid()">
                    <i class="bi bi-search"></i> Search
                </button>
                <button class="btn-ptc-outline" onclick="clearLeaveFilters()">
                    <i class="bi bi-x-circle"></i> Clear
                </button>
            </div>
        </div>
    </div>
</div>

@* ── Grid Card ── *@
<div class="ptc-card">
    <div class="ptc-card-header">
        <h2 class="ptc-card-title">
            <i class="bi bi-calendar-check"></i> Leave Records
        </h2>
        <span id="leaveRecordCount"
              style="font-size:0.75rem;color:var(--text-muted);background:#f1f5f9;
                     padding:3px 10px;border-radius:20px;">0 records</span>
    </div>
    <div class="ptc-card-body" style="padding:0;">
        <div id="leave_grid"></div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {

            kendo.culture('en-GB');

            /* ── Month DropDownList ─────────────────────────────────── */
            $('#queryLeaveMonth').kendoDropDownList({
                dataTextField:  'text',
                dataValueField: 'value',
                dataSource: [
                    { text: 'Jan', value: 1  }, { text: 'Feb', value: 2  },
                    { text: 'Mar', value: 3  }, { text: 'Apr', value: 4  },
                    { text: 'May', value: 5  }, { text: 'Jun', value: 6  },
                    { text: 'Jul', value: 7  }, { text: 'Aug', value: 8  },
                    { text: 'Sep', value: 9  }, { text: 'Oct', value: 10 },
                    { text: 'Nov', value: 11 }, { text: 'Dec', value: 12 }
                ],
                optionLabel: 'All Months',
                value: new Date().getMonth() + 1
                /* change handler added AFTER grid init */
            });

            /* ── Year DropDownList ──────────────────────────────────── */
            var cy = new Date().getFullYear();
            var yrs = [];
            for (var y = cy - 2; y <= cy + 1; y++) {
                yrs.push({ text: String(y), value: y });
            }

            $('#queryLeaveYear').kendoDropDownList({
                dataTextField:  'text',
                dataValueField: 'value',
                dataSource:     yrs,
                value:          cy
                /* change handler added AFTER grid init */
            });

            /* ── Enter key search ───────────────────────────────────── */
            $('#queryDriverName').on('keypress', function (e) {
                if (e.which === 13) refreshLeaveGrid();
            });

            /* ══════════════════════════════════════════════════════════
               KENDO GRID
               KEY CHANGES vs old approach:
               1. NO type: 'aspnetmvc-ajax'  — not needed, avoids DataSourceRequest
               2. parameterMap merges Kendo paging fields + custom filters
               3. schema same as before: data:'Data', total:'Total'
               4. [FromForm] KendoGridRequest on server reads page/pageSize/sort
            ══════════════════════════════════════════════════════════ */
            $('#leave_grid').kendoGrid({

                dataSource: {
                   
                    transport: {
                        read: {
                            url:  '@Url.Action("LeaveTransactionRead", "IGH")',
                            type: 'POST'
                            /* Default content-type is form-urlencoded — correct for [FromForm] */
                        },
                        update: {
                            url:  '@Url.Action("LeaveTransactionUpdate", "IGH")',
                            type: 'POST'
                        },
                        create: {
                            url:  '@Url.Action("LeaveTransactionCreate", "IGH")',
                            type: 'POST'
                        },
                        destroy: {
                            url:  '@Url.Action("LeaveTransactionDestroy", "IGH")',
                            type: 'POST'
                        },

                        parameterMap: function (data, operation) {
                            if (operation === 'read') {
                                /* Merge Kendo paging/sort fields with your custom filters */
                                /* Result posted as form fields — [FromForm] reads all of them */
                                return $.extend({}, data, getLeaveFilters());
                            }
                            /* update/create/destroy — return data as-is */
                            return data;
                        }
                    },

                    schema: {
                        data:   'Data',     /* matches KendoGridResult.Data   */
                        total:  'Total',    /* matches KendoGridResult.Total  */
                        errors: 'Errors',   /* matches KendoGridResult.Errors */
                        model: {
                            id: 'Id',
                            fields: {
                                Id:         { type: 'number', editable: false },
                                DriverId:   { type: 'number', editable: false },
                                DriverName: { type: 'string', editable: false },
                                LeaveDate:  { type: 'date'   },
                                LeaveCount: { type: 'number', validation: { min: 0.5, max: 31 } },
                                LeaveType:  { type: 'string' },
                                LeaveMonth: { type: 'number', editable: false },
                                Remarks:    { type: 'string' },
                                CreatedAt:  { type: 'date',   editable: false }
                            }
                        }
                    },

                    pageSize:      50,
                    serverPaging:  true,
                    serverSorting: true,
                    sort: { field: 'DriverName', dir: 'asc' },


                    requestEnd: function (e) {
                        if (e.type === 'read' && e.response) {
                            var total = e.response.Total || 0;
                            $('#leaveRecordCount').text(
                                total + ' record' + (total !== 1 ? 's' : ''));
                        }
                    },
                    error: function (e) { handleGridError(e); }
                },

                columns: [
                    { field: 'Id', hidden: true },
                    {
                        field: 'DriverName', title: 'Driver Name', width: 220,
                        template: '<span style="font-weight:600;">#: DriverName #</span>'
                    },
                    {
                        field: 'LeaveDate', title: 'Leave Date', width: 130,
                        template: function (d) {
                            if (!d.LeaveDate) return '';
                            return '<span style="font-family:Sora,sans-serif;font-size:0.8rem;">'
                                 + kendo.toString(kendo.parseDate(d.LeaveDate), 'dd-MMM-yyyy')
                                 + '</span>';
                        }
                    },
                    {
                        field: 'LeaveCount', title: 'Days', width: 80,
                        template: '<span style="font-weight:700;color:var(--accent);">#: LeaveCount #</span>',
                        attributes:       { style: 'text-align:center;' },
                        headerAttributes: { style: 'text-align:center;' }
                    },
                    {
                        field: 'LeaveType', title: 'Leave Type', width: 140,
                        template: function (d) {
                            if (!d.LeaveType) return '';
                            var colors = {
                                'AL': ['#dbeafe','#1d4ed8'], 'MC': ['#dcfce7','#15803d'],
                                'UL': ['#fef3c7','#92400e'], 'EL': ['#f3e8ff','#7e22ce'],
                                'PH': ['#ffe4e6','#be123c']
                            };
                            var c = colors[d.LeaveType.toUpperCase()] || ['#f1f5f9','#475569'];
                            return '<span style="background:' + c[0] + ';color:' + c[1]
                                 + ';font-size:0.7rem;font-weight:700;padding:2px 9px;'
                                 + 'border-radius:20px;">' + d.LeaveType + '</span>';
                        }
                    },
                    {
                        field: 'LeaveMonth', title: 'Month', width: 90,
                        template: function (d) {
                            var m = ['','Jan','Feb','Mar','Apr','May','Jun',
                                     'Jul','Aug','Sep','Oct','Nov','Dec'];
                            return m[d.LeaveMonth] || '';
                        },
                        attributes:       { style: 'text-align:center;' },
                        headerAttributes: { style: 'text-align:center;' }
                    },
                    {
                        field: 'Remarks', title: 'Remarks', width: 220,
                        template: '<span style="color:var(--text-secondary);font-size:0.82rem;">' +
                                  '#: Remarks || \'\' #</span>'
                    },
                    {
                        field: 'CreatedAt', title: 'Created At', width: 150,
                        template: function (d) {
                            if (!d.CreatedAt) return '';
                            return '<span style="font-size:0.78rem;color:var(--text-muted);">'
                                 + kendo.toString(kendo.parseDate(d.CreatedAt), 'dd-MMM-yyyy HH:mm')
                                 + '</span>';
                        }
                    },
                    {
                        command: [{
                            name: 'edit',
                            text: { edit: ' Edit', update: ' Save', cancel: ' Cancel' }
                        }],
                        title: 'Action', width: 160
                    }
                ],

                editable:   'inline',
                pageable:   { pageSize: 50, pageSizes: [25, 50, 100], buttonCount: 5 },
                sortable:   true,
                scrollable: true,
                height:     520,

                dataBound: function () {
                    this.thead.find('th').css({
                        'background':   '#f8fafc',
                        'font-weight':  '600',
                        'font-size':    '0.77rem',
                        'color':        '#475569',
                        'border-color': '#e2e8f0'
                    });
                },

                save: function () {
                    KSwal.toast('success', 'Leave record updated.');
                }
            });

            /* ── Add DDL change handlers AFTER grid is ready ────────── */
            $('#queryLeaveMonth').data('kendoDropDownList').bind('change', function () {
                refreshLeaveGrid();
            });
            $('#queryLeaveYear').data('kendoDropDownList').bind('change', function () {
                refreshLeaveGrid();
            });

            /* ── Initial load ───────────────────────────────────────── */
            refreshLeaveGrid();

        }); /* end document ready */


        /* ════════════════════════════════════════════════════════════
           getLeaveFilters()
           Returns your custom filter values as a plain object.
           parameterMap merges this with Kendo's paging/sort fields.
           Server receives everything as [FromForm] parameters.
        ════════════════════════════════════════════════════════════ */
        function getLeaveFilters() {
            var monthDdl = $('#queryLeaveMonth').data('kendoDropDownList');
            var yearDdl  = $('#queryLeaveYear').data('kendoDropDownList');

            var mVal = monthDdl ? parseInt(monthDdl.value()) : 0;
            var yVal = yearDdl  ? parseInt(yearDdl.value())  : 0;
            var name = $('#queryDriverName').val().trim();

            return {
                leaveMonth: isNaN(mVal) ? 0 : mVal,
                leaveYear:  isNaN(yVal) ? 0 : yVal,
                driverName: name
            };
        }

        /* ════════════════════════════════════════════════════════════
           refreshLeaveGrid()
           Use query() — single request, no race condition
        ════════════════════════════════════════════════════════════ */
        function refreshLeaveGrid() {
            var grid = $('#leave_grid').data('kendoGrid');
            if (!grid) return;
            grid.dataSource.query({
                page:     1,
                pageSize: grid.dataSource.pageSize(),
                sort:     grid.dataSource.sort()
            });

             kendo.ui.progress($("#leave_grid"), false);
        }

        function clearLeaveFilters() {
            var monthDdl = $('#queryLeaveMonth').data('kendoDropDownList');
            var yearDdl  = $('#queryLeaveYear').data('kendoDropDownList');
            if (monthDdl) monthDdl.value('');
            if (yearDdl)  yearDdl.value(new Date().getFullYear());
            $('#queryDriverName').val('');
            refreshLeaveGrid();
        }

        function exportLeaveGrid() {
            var grid = $('#leave_grid').data('kendoGrid');
            if (grid) { grid.saveAsExcel(); KSwal.toast('info', 'Exporting...'); }
        }

        function openAddLeaveModal() {
            KSwal.alert('Add Leave form coming soon.', 'Add Leave', 'info');
        }

        function handleGridError(e) {
            var msg = 'An error occurred loading leave records.';
            if (e.errors) {
                var parts = [];
                $.each(e.errors, function (k, v) {
                    if (v.errors) parts.push(v.errors.join('\n'));
                    else if (typeof v === 'string') parts.push(v);
                });
                if (parts.length) msg = parts.join('\n');
            } else if (e.xhr) {
                console.error('Grid error:', e.xhr.status, e.xhr.responseText);
                if (e.xhr.status === 401) msg = 'Session expired. Please log in again.';
                if (e.xhr.status === 403) msg = 'You do not have permission to view this data.';
                if (e.xhr.status === 404) msg = 'Action not found. Check controller route.';
                if (e.xhr.status === 500) msg = 'Server error. Check application logs.';
            }
            KSwal.error('Grid Error', msg);
        }
    </script>
}
